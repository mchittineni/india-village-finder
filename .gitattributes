# Normalise line endings to LF on checkin
* text=auto eol=lf

# Keep binary-ish / data files from being line-ending mangled
*.png binary
*.jpg binary
*.7z binary
*.zip binary

# --- Generated per-state web apps -------------------------------------------
# The single source of truth for the UI is scraper/web_template/. The copies in
# each <state>/web/ are generated by the pipeline — collapse them in diffs and
# exclude them from GitHub's language statistics so the stats reflect real source.
*/web/app.js        linguist-generated=true
*/web/i18n.js       linguist-generated=true
*/web/index.html    linguist-generated=true
*/web/styles.css    linguist-generated=true
*/web/config.js     linguist-generated=true

# --- Generated datasets ------------------------------------------------------
# Large machine-generated data — mark as generated so they don't dominate the
# language bar or clutter diffs/reviews.
*/web/data/*.json    linguist-generated=true
*/web/data/*.geojson linguist-generated=true
*/data/*.csv         linguist-generated=true
